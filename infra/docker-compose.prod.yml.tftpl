x-app-env: &app-env
  APP_ENV: prod
  APP_DEBUG: "0"
  APP_SECRET: $${APP_SECRET:?APP_SECRET is required}
  DATABASE_URL: $${DATABASE_URL:?DATABASE_URL is required}
  OPENAI_API_KEY: $${OPENAI_API_KEY:?OPENAI_API_KEY is required}
  OPENAI_MODEL: $${OPENAI_MODEL:-gpt-4.1-mini}
  OPENAI_MAX_TOKENS: $${OPENAI_MAX_TOKENS:-800}
  OPENAI_TEMPERATURE: $${OPENAI_TEMPERATURE:-0.1}
  CODE_AGENT: $${CODE_AGENT:-codex}
  CODEX_MODEL: $${CODEX_MODEL:-gpt-5.3-codex}
  AUTOFIX_GIT_USER_NAME: $${AUTOFIX_GIT_USER_NAME:-Darkmira Bot}
  AUTOFIX_GIT_USER_EMAIL: $${AUTOFIX_GIT_USER_EMAIL:-bot@darkmira.fr}
  GITHUB_TOKEN: $${GITHUB_TOKEN:?GITHUB_TOKEN is required}
  MAILBOX_MAX_RESULTS: $${MAILBOX_MAX_RESULTS:-25}
  GMAIL_OAUTH_CLIENT_ID: $${GMAIL_OAUTH_CLIENT_ID:?GMAIL_OAUTH_CLIENT_ID is required}
  GMAIL_OAUTH_CLIENT_SECRET: $${GMAIL_OAUTH_CLIENT_SECRET:?GMAIL_OAUTH_CLIENT_SECRET is required}
  GMAIL_OAUTH_REFRESH_TOKEN: $${GMAIL_OAUTH_REFRESH_TOKEN:?GMAIL_OAUTH_REFRESH_TOKEN is required}
  GMAIL_OAUTH_REDIRECT_URI: $${GMAIL_OAUTH_REDIRECT_URI:-http://localhost:8080/oauth2callback}

services:
  app:
    image: $${APP_IMAGE:-ghcr.io/jonathangreco/darkmira-maintenance-app:prod}
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "php-fpm", "-t"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    environment:
      <<: *app-env
      RUN_MIGRATIONS: $${RUN_MIGRATIONS:-0}
      WARMUP_CACHE: $${WARMUP_CACHE:-1}
    volumes:
      - /var/darkmira/config:/var/darkmira/config:ro
      - repos_data:/var/darkmira/repos
    networks:
      - internal

  nginx:
    image: $${NGINX_IMAGE:-ghcr.io/jonathangreco/darkmira-maintenance-nginx:prod}
    restart: unless-stopped
    depends_on:
      app:
        condition: service_healthy
    ports:
      - "$${NGINX_PORT:-8080}:80"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost/nginx-health | grep OK"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 20s
    networks:
      - internal

  messenger-worker:
    image: $${APP_IMAGE:-ghcr.io/jonathangreco/darkmira-maintenance-app:prod}
    restart: unless-stopped
    command: php bin/console messenger:consume async --memory-limit=512M -vv
    depends_on:
      app:
        condition: service_healthy
    environment:
      <<: *app-env
      RUN_MIGRATIONS: "0"
      WARMUP_CACHE: "0"
    volumes:
      - /var/darkmira/config:/var/darkmira/config:ro
      - repos_data:/var/darkmira/repos
    networks:
      - internal

  scheduler:
    image: $${APP_IMAGE:-ghcr.io/jonathangreco/darkmira-maintenance-app:prod}
    restart: unless-stopped
    command: php bin/console messenger:consume scheduler_default --memory-limit=256M -vv
    depends_on:
      app:
        condition: service_healthy
    environment:
      <<: *app-env
      RUN_MIGRATIONS: "0"
      WARMUP_CACHE: "0"
    volumes:
      - /var/darkmira/config:/var/darkmira/config:ro
    networks:
      - internal

volumes:
  repos_data:

networks:
  internal:
    driver: bridge
