---

# 2. `.gitignore`

```gitignore id="gitignore"
# Terraform local directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform variable files containing secrets
*.tfvars
*.tfvars.json

# Keep examples
!*.tfvars.example
!infra/dev.tfvars

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# OS / editor
.DS_Store
.idea/
.vscode/

# Environment files
.env
.env.*
!.env.example
